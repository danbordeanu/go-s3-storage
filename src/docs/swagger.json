                "operationId": "createbucket",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Name of the bucket to create",
                        "name": "bucket",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "AWS4-HMAC-SHA256 authorization header (required if S3_AUTH_ENABLED=true)",
