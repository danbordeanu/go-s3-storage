            },
            "head": {
                "description": "Checks if a bucket exists and you have permission to access it",
                "tags": [
                    "buckets"
                ],
                "summary": "Check if bucket exists",
                "operationId": "headbucket",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Name of the bucket to check",
