                    "404": {
                        "description": "Bucket not found",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    }
                }
            },
            "put": {
