{
    "swagger": "2.0",
    "info": {
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support"
        }
    },
    "paths": {
        "/": {
            "get": {
                "description": "Returns a list of all buckets owned by the authenticated sender of the request",
                "produces": [
                    "text/xml"
                ],
                "tags": [
                    "buckets"
                ],
                "summary": "List all buckets",
                "operationId": "listbuckets",
                "parameters": [
                    {
                        "type": "string",
                        "description": "AWS4-HMAC-SHA256 authorization header (required if S3_AUTH_ENABLED=true)",
                        "name": "Authorization",
                        "in": "header"
                    },
                    {
                        "type": "string",
                        "description": "Request timestamp in ISO 8601 format (required if S3_AUTH_ENABLED=true)",
                        "name": "X-Amz-Date",
                        "in": "header"
                    },
                    {
                        "type": "string",
                        "description": "SHA256 hash of request payload or 'UNSIGNED-PAYLOAD' (required if S3_AUTH_ENABLED=true)",
                        "name": "X-Amz-Content-SHA256",
                        "in": "header"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of all buckets with owner information",
                        "schema": {
                            "$ref": "#/definitions/model.ListAllMyBucketsResult"
                        }
                    },
                    "403": {
                        "description": "Access denied or signature mismatch",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    },
                    "503": {
                        "description": "Service unavailable",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    }
                }
            }
        },
        "/share/create/{bucket}/{key}": {
            "post": {
                "description": "Generates a unique public link that allows downloading an object without authentication",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sharing"
                ],
                "summary": "Create a public share link for an object",
                "operationId": "createsharelink",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Name of the bucket",
                        "name": "bucket",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Object key (path)",
                        "name": "key",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "default": 0,
                        "description": "Expiration time in seconds (0 for no expiration)",
                        "name": "expires_in",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "AWS4-HMAC-SHA256 authorization header (required if S3_AUTH_ENABLED=true)",
                        "name": "Authorization",
                        "in": "header"
                    },
                    {
                        "type": "string",
                        "description": "Request timestamp in ISO 8601 format (required if S3_AUTH_ENABLED=true)",
                        "name": "X-Amz-Date",
                        "in": "header"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Share link created successfully",
                        "schema": {
                            "$ref": "#/definitions/model.CreateShareLinkResponse"
                        }
                    },
                    "403": {
                        "description": "Access denied or signature mismatch",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    },
                    "404": {
                        "description": "Bucket or object not found",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    }
                }
            }
        },
        "/share/{token}": {
            "get": {
                "description": "Downloads an object using a public share token without authentication",
                "produces": [
                    "application/octet-stream"
                ],
                "tags": [
                    "sharing"
                ],
                "summary": "Download an object via public share link",
                "operationId": "getsharedobject",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Share link token",
                        "name": "token",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Object data",
                        "schema": {
                            "type": "file"
                        },
                        "headers": {
                            "Content-Length": {
                                "type": "string",
                                "description": "Size of the object in bytes"
                            },
                            "Content-Type": {
                                "type": "string",
                                "description": "MIME type of the object"
                            },
                            "ETag": {
                                "type": "string",
                                "description": "MD5 hash of the object (quoted)"
                            },
                            "Last-Modified": {
                                "type": "string",
                                "description": "Last modification time (RFC1123 format)"
                            }
                        }
                    },
                    "403": {
                        "description": "Share link expired",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    },
                    "404": {
                        "description": "Share link not found or object deleted",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    }
                }
            },
            "delete": {
                "description": "Revokes a public share link by deleting it",
                "tags": [
                    "sharing"
                ],
                "summary": "Delete a share link",
                "operationId": "deletesharelink",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Share link token",
                        "name": "token",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "AWS4-HMAC-SHA256 authorization header (required if S3_AUTH_ENABLED=true)",
                        "name": "Authorization",
                        "in": "header"
                    },
                    {
                        "type": "string",
                        "description": "Request timestamp in ISO 8601 format (required if S3_AUTH_ENABLED=true)",
                        "name": "X-Amz-Date",
                        "in": "header"
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Share link deleted successfully"
                    },
                    "403": {
                        "description": "Access denied or signature mismatch",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    },
                    "404": {
                        "description": "Share link not found",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/model.S3Error"
                        }
                    }
                }
            }
        },
        "/{bucket}": {
            "get": {
                "description": "Returns a list of objects in the specified bucket (S3 ListObjectsV2 compatible)",
                "produces": [
                    "text/xml"
                ],
                "tags": [
                    "objects"
                ],
                "summary": "List objects in a bucket",
                "operationId": "listobjects",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Bucket name",
                        "name": "bucket",
                        "in": "path",
                        "required": true
                    },
                    {
                        "enum": [
                            2
                        ],
                        "type": "integer",
                        "description": "S3 list API version (must be 2 for ListObjectsV2)",
                        "name": "list-type",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Limits the response to keys that begin with the specified prefix",
                        "name": "prefix",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Character used to group keys (usually /)",
                        "name": "delimiter",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 1000,
                        "description": "Maximum number of keys returned",
                        "name": "max-keys",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "AWS4-HMAC-SHA256 authorization header (required if S3_AUTH_ENABLED=true)",
                        "name": "Authorization",
                        "in": "header"
                    },
                    {
                        "type": "string",
                        "description": "Request timestamp in ISO 8601 format (required if S3_AUTH_ENABLED=true)",
                        "name": "X-Amz-Date",
                        "in": "header"
