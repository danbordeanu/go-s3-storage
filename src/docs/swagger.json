    "definitions": {
        "model.Bucket": {
            "description": "Individual bucket information",
            "type": "object",
            "properties": {
                "creationDate": {
                    "description": "Date and time when the bucket was created in RFC3339 format",
                    "type": "string",
                    "example": "2024-01-15T10:30:00Z"
                },
                "name": {
                    "description": "Name of the bucket",
                    "type": "string",
                    "example": "my-bucket"
                }
            }
        },
        "model.Buckets": {
            "description": "Container for the list of buckets",
            "type": "object",
            "properties": {
                "bucket": {
                    "description": "List of buckets",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.Bucket"
                    }
                }
            }
        },
        "model.CommonPrefix": {
            "description": "Common prefix representing a virtual folder",
            "type": "object",
            "properties": {
                "prefix": {
                    "description": "The prefix (folder path)",
                    "type": "string",
                    "example": "documents/"
                }
            }
        },
        "model.CreateShareLinkResponse": {
            "type": "object",
            "properties": {
                "bucket": {
                    "type": "string"
                },
                "expires_at": {
                    "type": "integer"
                },
                "expires_in": {
                    "type": "integer"
                },
                "key": {
                    "type": "string"
                },
                "share_url": {
                    "type": "string"
                },
                "token": {
                    "type": "string"
                }
            }
        },
