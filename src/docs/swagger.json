                    {
                        "type": "string",
                        "description": "SHA256 hash of request payload or 'UNSIGNED-PAYLOAD' (required if S3_AUTH_ENABLED=true)",
                        "name": "X-Amz-Content-SHA256",
                        "in": "header"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Bucket created successfully",
