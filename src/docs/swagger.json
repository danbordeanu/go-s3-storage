            },
            "delete": {
                "description": "Deletes the specified bucket. The bucket must be empty before it can be deleted",
                "produces": [
                    "text/xml"
                ],
                "tags": [
                    "buckets"
                ],
                "summary": "Delete a bucket",
                "operationId": "deletebucket",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Name of the bucket to delete",
                        "name": "bucket",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "AWS4-HMAC-SHA256 authorization header (required if S3_AUTH_ENABLED=true)",
                        "name": "Authorization",
                        "in": "header"
                    },
                    {
                        "type": "string",
                        "description": "Request timestamp in ISO 8601 format (required if S3_AUTH_ENABLED=true)",
                        "name": "X-Amz-Date",
                        "in": "header"
                    },
                    {
                        "type": "string",
                        "description": "SHA256 hash of request payload or 'UNSIGNED-PAYLOAD' (required if S3_AUTH_ENABLED=true)",
